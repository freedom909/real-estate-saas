FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies (including dev for tsx/ts-node at build)
RUN npm install --no-audit --no-fund

# Copy source code - use build arg to bust cache
ARG CACHE_BUST=1
COPY . .

# Railway assigns PORT dynamically - no EXPOSE needed
# Subgraphs run internally on fixed ports, gateway on $PORT

CMD ["bash", "scripts/start-railway.sh"]
